{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/vendor/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}